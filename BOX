-- HELPER: Toggle neon
-- ============================================================
local function makeToggle(label, colorType, layoutOrder, parentContent)
    local Row = Instance.new("Frame")
    Row.Size               = UDim2.new(1, 0, 0, 24)
    Row.BackgroundTransparency = 1
    Row.LayoutOrder        = layoutOrder
    Row.ZIndex             = 14
    Row.Parent             = parentContent

    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(0.6, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text               = label
    lbl.TextColor3         = C.textMuted
    lbl.Font               = Enum.Font.GothamBold
    lbl.TextSize           = 12
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.ZIndex             = 15
    lbl.Parent             = Row

    local status = Instance.new("TextLabel")
    status.Size               = UDim2.new(0, 36, 1, 0)
    status.Position           = UDim2.new(1, -84, 0, 0)
    status.BackgroundTransparency = 1
    status.Text               = "OFF"
    status.TextColor3         = C.offKnob
    status.Font               = Enum.Font.GothamBold
    status.TextSize           = 11
    status.TextXAlignment     = Enum.TextXAlignment.Right
    status.ZIndex             = 15
    status.Parent             = Row

    local track = Instance.new("TextButton")
    track.Size             = UDim2.new(0, 48, 0, 24)
    track.Position         = UDim2.new(1, -50, 0.5, -12)
    track.BackgroundColor3 = C.trackOff
    track.Text             = ""
    track.BorderSizePixel  = 0
    track.ZIndex           = 15
    track.Parent           = Row
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    local ts = Instance.new("UIStroke", track)
    ts.Color = C.border; ts.Thickness = 1

    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0, 18, 0, 18)
    knob.Position         = UDim2.new(0, 3, 0.5, -9)
    knob.BackgroundColor3 = C.offKnob
    knob.BorderSizePixel  = 0
    knob.ZIndex           = 16
    knob.Parent           = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local tw     = TweenInfo.new(0.15, Enum.EasingStyle.Quad)
    local onCol  = colorType == "box" and C.neonCyan or C.neonGreen
    local onTrk  = colorType == "box" and C.trackBox or Color3.fromRGB(8, 55, 40)
    local isOn   = false

    local function set(val)
        isOn = val
        if val then
            TweenService:Create(track, tw, {BackgroundColor3 = onTrk}):Play()
            TweenService:Create(knob,  tw, {
                Position         = UDim2.new(0, 27, 0.5, -9),
                BackgroundColor3 = onCol,
            }):Play()
            local ks = knob:FindFirstChildOfClass("UIStroke")
            if not ks then ks = Instance.new("UIStroke", knob) end
            ks.Color = onCol; ks.Thickness = 1.5
            ts.Color = onCol
            status.Text       = "ON"
            status.TextColor3 = onCol
            lbl.TextColor3    = C.textMain
        else
            TweenService:Create(track, tw, {BackgroundColor3 = C.trackOff}):Play()
            TweenService:Create(knob,  tw, {
                Position         = UDim2.new(0, 3, 0.5, -9),
                BackgroundColor3 = C.offKnob,
            }):Play()
            local ks = knob:FindFirstChildOfClass("UIStroke")
            if ks then ks:Destroy() end
            ts.Color          = C.border
            status.Text       = "OFF"
            status.TextColor3 = C.offKnob
            lbl.TextColor3    = C.textMuted
        end
    end

    return track, set, function() return isOn end
end

