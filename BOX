-- ============================================================
-- TIMING
-- ============================================================
local T = {
    claim_delay  = 0.01,
    open_box     = 0.01,
    loop_rest    = 0.01,
}

-- ============================================================
-- STATE & THREADS
-- ============================================================
local State = {
    all_box   = false,
    minimized = false,
}
local Threads = {}

-- ============================================================
-- ACTIONS
-- ============================================================

local function doClaim(boxName)
    pcall(function()
        RS:WaitForChild("ServerMsg"):WaitForChild("Code"):InvokeServer(boxName)
    end)
end

local function doOpen(boxName, repeatCount)
    local id = BOX_IDS[boxName]
    if not id or id == 0 then return end
    local count = repeatCount or 1
    for i = 1, count do
        pcall(function()
            RS:WaitForChild("Msg"):WaitForChild("RemoteFunction"):InvokeServer("OpenSouvenirBox", id)
        end)
        task.wait(T.open_box)
    end
end

-- ============================================================
-- LOOP ENGINE
-- ============================================================

local function runBoxLoop(key, boxes)
    State[key] = true
    Threads[key] = task.spawn(function()
        while State[key] do
            for _, box in ipairs(boxes) do
                if not State[key] then break end
                doClaim(box)
                task.wait(T.claim_delay)
            end
            for _, box in ipairs(boxes) do
                if not State[key] then break end
                local repeatCount = BOX_REPEAT[box] or 1
                doOpen(box, repeatCount)
            end
            if State[key] then task.wait(T.loop_rest) end
        end
    end)
end

local function stopLoop(key)
    State[key] = false
    if Threads[key] then
        pcall(task.cancel, Threads[key])
        Threads[key] = nil
    end
end

