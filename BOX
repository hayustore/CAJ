-- ============================================================
-- DRAG
-- ============================================================
do
    local dragging, dragStart, startPos = false, nil, nil
    Main.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = inp.Position
            startPos  = Main.Position
        end
    end)
    Main.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and (
            inp.UserInputType == Enum.UserInputType.MouseMovement or
            inp.UserInputType == Enum.UserInputType.Touch
        ) then
            local d = inp.Position - dragStart
            local nx = startPos.X.Offset + d.X
            local ny = startPos.Y.Offset + d.Y
            Main.Position   = UDim2.new(0, nx, 0, ny)
            Shadow.Position = UDim2.new(0, nx - 3, 0, ny - 3)
        end
    end)
end

-- ============================================================
-- RESIZE
-- ============================================================
do
    local SCALE_STEP = 0.15
    local MIN_SCALE  = 0.4
    local MAX_SCALE  = 2
    local curScale   = 1

    local function makeSBtn(text, offsetRight)
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(0, 22, 0, 20)
        btn.Position         = UDim2.new(1, offsetRight, 0.5, -10)
        btn.BackgroundColor3 = C.btnBg
        btn.Text             = text
        btn.TextColor3       = C.textMuted
        btn.Font             = Enum.Font.GothamBold
        btn.TextSize         = 13
        btn.BorderSizePixel  = 0
        btn.ZIndex           = 14
        btn.Parent           = TitleBar
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
        local s = Instance.new("UIStroke", btn)
        s.Color = C.border; s.Thickness = 1
        return btn
    end

    local BtnShrink = makeSBtn("−", -170)
    local BtnGrow   = makeSBtn("+", -146)

    local function applyScale(newScale)
        newScale = math.clamp(newScale, MIN_SCALE, MAX_SCALE)
        curScale = newScale
        local nw = math.floor(WIN_W * curScale)
        local nh = math.floor(FULL_H * curScale)
        TweenService:Create(Main, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, nw, 0, nh)
        }):Play()
        task.delay(0.2, syncShadow)
    end

    BtnShrink.MouseButton1Click:Connect(function()
        applyScale(curScale - SCALE_STEP)
    end)
    BtnGrow.MouseButton1Click:Connect(function()
        applyScale(curScale + SCALE_STEP)
    end)

    addHover(BtnShrink, C.btnBg, C.btnHov)
    addHover(BtnGrow,   C.btnBg, C.btnHov)
end

